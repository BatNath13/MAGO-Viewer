# Connexion PostgreSQL — copie ce fichier en ".env" et renseigne le mot de passe
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=ton_mot_de_passe_postgres
PGDATABASE=mago_enrichment

# Base PostgreSQL séparée pour les accès client
# Les tables attribute/object/model restent dans PGDATABASE.
# Les identifiants, mots de passe et expirations vont dans ACCESS_PGDATABASE.
ACCESS_PGDATABASE=mago_access

# Port d'écoute de l'API
PORT=3001

# --- Accès client avec base de données ---
# URL publique du viewer/API. Sert à remplir automatiquement la colonne lien_client.
# En local : http://localhost:3001
# En ligne : https://ton-domaine.fr
CLIENT_PUBLIC_BASE_URL=http://localhost:3001

# Secret de signature des jetons
# Génération : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=remplace_par_un_secret_long_et_aleatoire

# Durée de vie du jeton client. La base est quand même revérifiée à chaque requête.
CLIENT_TOKEN_TTL=12h

# Fuseau utilisé par le CLI admin pour --expires "AAAA-MM-JJ HH:mm"
CLIENT_EXPIRY_TIMEZONE=Europe/Paris

# true sur le déploiement client hébergé : l'enrichissement exige alors un compte valide
CLIENT_AUTH_REQUIRED=false

# Dossier où sont stockées les scènes client, hors public/
STORAGE_DIR=./storage

# Tunnel public automatique lancé depuis le bouton « Créer vue client ».
# Laisse par défaut, sauf installation spéciale de cloudflared.
CLIENT_LOCAL_VIEWER_URL=http://localhost:3001
# CLOUDFLARED_EXE=C:\Users\<toi>\AppData\Local\Microsoft\WinGet\Links\cloudflared.exe
