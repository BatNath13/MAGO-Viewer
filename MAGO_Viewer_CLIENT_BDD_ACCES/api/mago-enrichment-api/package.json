{
  "name": "mago-enrichment-api",
  "version": "1.0.0",
  "description": "Backend REST pour l'enrichissement sémantique MAGO (PostgreSQL + Fastify)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "admin": "tsx src/admin.ts",
    "migrate": "psql \"$DATABASE_URL\" -f sql/001_client_access.sql"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "@fastify/jwt": "^9.0.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/bcryptjs": "^2.4.6"
  }
}